{
  "name": "文档base64上传",
  "endpoint": "anthropic",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "messages": [
      {"role": "user", "content": [
        {"type": "text", "text": "请告诉我这个文档的内容，只回复文件中的原文即可。"},
        {"type": "document", "source": {"type": "base64", "media_type": "text/plain", "data": "VGhpcyBpcyBhIHRlc3QgZG9jdW1lbnQgdXBsb2FkZWQgdmlhIGRzLWZyZWUtYXBpIGZpbGUgdXBsb2FkIGZlYXR1cmUu"}}
      ]}
    ],
    "max_tokens": 1024,
    "stream": false
  },
  "checks": {
    "content_not_empty": true,
    "stop_reason": "end_turn"
  }
}
